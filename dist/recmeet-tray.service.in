[Unit]
Description=Recmeet Meeting Recorder Tray
Documentation=https://github.com/suykerbuyk/recmeet
PartOf=graphical-session.target
Wants=recmeet-daemon.service
After=graphical-session.target recmeet-daemon.service

[Service]
Type=simple
ExecStart=@RECMEET_TRAY_EXEC@
Environment=RECMEET_LOG_LEVEL=error
Restart=on-failure
RestartSec=5

[Install]
WantedBy=graphical-session.target
